{
  "appId": "com.paperkraft.app",
  "productName": "PaperKraft",
  "directories": {
    "output": "dist"
  },
  "files": [
    "electron/**/*",
    "out/**/*",
    "package.json"
  ],
  "extraResources": [
    {
      "from": "resources",
      "to": "resources",
      "filter": ["**/*"]
    },
    {
      "from": "helpers",
      "to": "helpers",
      "filter": ["**/*"]
    }
  ],
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": [
          "x64"
        ]
      }
    ],
    "icon": "public/icon.ico",
    "signAndEditExecutable": false
  },
  "mac": {
    "target": "dmg",
    "icon": "public/icon.icns",
    "category": "public.app-category.productivity"
  },
  "linux": {
    "target": [
      "AppImage",
      "deb"
    ],
    "icon": "public/icon.png",
    "category": "Office"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true
  }
}
